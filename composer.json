{
    "name": "precision-soft/doctrine-utility",
    "type": "library",
    "description": "doctrine utilities library",
    "keywords": [
        "doctrine",
        "repository"
    ],
    "homepage": "https://github.com/precision-soft/doctrine-utility",
    "license": "MIT",
    "authors": [
        {
            "name": "Adrian Jeledintan",
            "email": "adrian.jeledintan@precision-soft.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "doctrine/dbal": "4.*",
        "doctrine/orm": "3.*",
        "doctrine/persistence": "3.*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "3.*",
        "phpstan/phpstan": "^2.0",
        "precision-soft/symfony-phpunit": "2.*"
    },
    "autoload": {
        "psr-4": {
            "PrecisionSoft\\Doctrine\\Utility\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PrecisionSoft\\Doctrine\\Utility\\Test\\": "tests/"
        }
    },
    "scripts": {
        "install-hooks": [
            "[ $COMPOSER_DEV_MODE -eq 1 ] && rm -rf .git/hooks && ln -s ../.dev/git-hooks .git/hooks || exit 0"
        ],
        "post-install-cmd": [
            "@install-hooks"
        ],
        "post-update-cmd": [
            "@install-hooks"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
